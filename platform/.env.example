# ── Database ──────────────────────────────────────────────────────────────────
# Platform tables (platform.* schema)
DATABASE_URL=postgres://node3:password@localhost:5432/node3

# Rubix node database — where fullnode_transactions lives.
# Must match the -dbUsername/-dbPassword/-dbName/-dbPort flags passed to rubixgoplatform
# in rubix-node0.service. The rubix node defaults to port 5500; the service overrides
# it to 5432 so both the node and the platform connect to the same Postgres instance.
RUBIX_DATABASE_URL=postgres://rubix:rubixpass@localhost:5432/rubixdb

# ── Auth ──────────────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather. Used to verify Login Widget HMAC.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Secrets ───────────────────────────────────────────────────────────────────
# SERVER_SECRET: HMAC key for deriving per-account DID passwords.
# NEVER rotate this after first deployment — changing it invalidates every
# custodial DID keypair stored on the node.
# Generate with: openssl rand -hex 32
SERVER_SECRET=change_me_generate_with_openssl_rand_hex_32

# CALLBACK_SECRET: HMAC key for per-contract callback URL tokens.
# Rotating this only invalidates existing callback URLs (re-register to fix).
# Generate with: openssl rand -hex 32
CALLBACK_SECRET=change_me_generate_with_openssl_rand_hex_32

# Directory where uploaded .wasm contract binaries are stored.
# Must be on a persistent volume in Docker/k8s.
WASM_DIR=/opt/node3/wasm

# ── Billing (Lemon Squeezy) ───────────────────────────────────────────────────
# Webhook signing secret — found in LS dashboard → Webhooks → your endpoint.
LEMON_WEBHOOK_SECRET=your_lemon_webhook_secret

# API key — found in LS dashboard → API Keys.
LEMON_API_KEY=your_lemon_api_key

# Variant ID of the Pro plan product — found in LS dashboard → Products.
LEMON_VARIANT_ID=123456

# ── Server ────────────────────────────────────────────────────────────────────
PLATFORM_URL=https://node3.cloud
PORT=8080
