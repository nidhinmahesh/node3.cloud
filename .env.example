# ── node3.cloud environment variables ────────────────────────────────────────
# Copy this file to .env and fill in every value before running docker compose.
# .env is in .gitignore and must NEVER be committed.
#
# Generate random secrets with:
#   openssl rand -hex 32

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=node3
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=platformdb
RUBIX_DB=rubixdb

# ── Platform Go service ───────────────────────────────────────────────────────
# SESSION_SECRET: used to sign session tokens (random hex, 32+ bytes)
SERVER_SECRET=

# CALLBACK_SECRET: HMAC secret the platform uses to verify SC callback payloads
CALLBACK_SECRET=

# Telegram bot that powers the login widget.
# Create a bot at https://t.me/BotFather and enable the "Allow groups?" + "Allow login" options.
TELEGRAM_BOT_TOKEN=

# Lemon Squeezy — billing
# Webhook signing secret: Lemon Squeezy dashboard → Webhooks → Signing Secret
LEMON_WEBHOOK_SECRET=
# API key: Lemon Squeezy dashboard → API Keys
LEMON_API_KEY=
# Variant ID of the single paid plan product
LEMON_VARIANT_ID=

# Public URL of the platform (used in CORS and callback URLs).
PLATFORM_URL=https://node3.cloud

# ── SvelteKit portal (baked in at nginx image build time) ────────────────────
# Telegram bot username WITHOUT the @ prefix (e.g. node3cloudbot)
VITE_TELEGRAM_BOT=

# ── Rubix node ────────────────────────────────────────────────────────────────
# Branch or tag of rubixgoplatform to clone when building the node0 image.
RUBIX_BRANCH=release-v1
